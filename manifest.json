{
  "manifest_version": 3,
  "name": "MITM Detector",
  "version": "2.0.0",
  "description": "Detects AND prevents Man-in-the-Middle attacks: SSL stripping, HTTPS downgrade, certificate changes, script injection, and more.",
  "permissions": [
    "webRequest",
    "webNavigation",
    "declarativeNetRequest",
    "storage",
    "notifications",
    "tabs",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MITM Detector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocking_page.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
